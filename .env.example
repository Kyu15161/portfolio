# Database URL (SQLite locally, PostgreSQL in production)
DATABASE_URL="file:./dev.db"

# JWT secret key for signing admin session tokens
JWT_SECRET="your-super-secure-jwt-secret-key"

# SHA-256 hash of your admin password (e.g. for "admin" use "8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918")
ADMIN_PASSWORD_SHA256="8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918"

# Cloudinary Credentials (Optional - fallback to public/uploads local directory if not provided)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"
